        ) : (
          <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2">
            {usMovers.map(item => (
              <div
                key={item.symbol}
                className={`rounded-lg border p-2.5 ${bgColorClass(item.changePct)} hover:shadow-sm transition-shadow`}
                title={`${item.name} — 昨收价格`}
